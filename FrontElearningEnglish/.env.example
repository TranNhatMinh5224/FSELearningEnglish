# ==========================================
# Frontend Environment Variables
# ==========================================

# ============================================
# API Configuration
# ============================================
# API Backend URL - Use relative path for nginx proxy
REACT_APP_API_BASE_URL=/api

# For direct API access (without nginx proxy):
# REACT_APP_API_BASE_URL=http://localhost:5030/api
# For IP deployment: REACT_APP_API_BASE_URL=http://YOUR_IP:5030/api
# For domain: REACT_APP_API_BASE_URL=https://yourdomain.com/api

# ============================================
# Frontend URL (for OAuth callbacks)
# ============================================
REACT_APP_FRONTEND_URL=http://localhost:3000
# For IP deployment: REACT_APP_FRONTEND_URL=http://YOUR_IP:3000
# For domain: REACT_APP_FRONTEND_URL=https://yourdomain.com

# ============================================
# Google OAuth Configuration
# ============================================
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id-here
# Redirect URI will auto-generate from FRONTEND_URL if not set
REACT_APP_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# For IP: REACT_APP_GOOGLE_REDIRECT_URI=http://YOUR_IP:3000/auth/google/callback
# For domain: REACT_APP_GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# ============================================
# Facebook OAuth Configuration
# ============================================
REACT_APP_FACEBOOK_APP_ID=your-facebook-app-id-here
# Redirect URI will auto-generate from FRONTEND_URL if not set
REACT_APP_FACEBOOK_REDIRECT_URI=http://localhost:3000/auth/facebook/callback
# For IP: REACT_APP_FACEBOOK_REDIRECT_URI=http://YOUR_IP:3000/auth/facebook/callback
# For domain: REACT_APP_FACEBOOK_REDIRECT_URI=https://yourdomain.com/auth/facebook/callback

# ==========================================
# Production Environment Example
# ==========================================
# REACT_APP_API_BASE_URL=https://api.catalunya-english.com/api
# REACT_APP_GOOGLE_REDIRECT_URI=https://catalunya-english.com/auth/google/callback
# REACT_APP_FACEBOOK_REDIRECT_URI=https://catalunya-english.com/auth/facebook/callback
# REACT_APP_FRONTEND_URL=https://catalunya-english.com
